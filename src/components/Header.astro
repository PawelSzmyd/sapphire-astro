---
// Górne menu nawigacyjne. Na desktopie linki są widoczne w linii (jak wcześniej).
// Poniżej 980px chowamy je za przyciskiem hamburgera — bez tego mobile nie miało
// żadnej nawigacji (.nav-links { display:none } bez przełącznika).
---

<header class="site-header" aria-label="Główna nawigacja">
  <a class="brand" href="/" aria-label="SAPPHIRE Apartments">
    <img id="header-logo" src="/assets/sapphire-logo-white.svg" alt="SAPPHIRE Apartments" />
  </a>

  <nav class="nav-links" id="nav-links">
    <a href="/o-sapphire-apartments">O Sapphire Apartments</a>
    <a href="/rezydencje/adhara">Adhara</a>
    <a href="/rezydencje/urban-sky">Urban Sky</a>
    <a href="/rezydencje/villa-del-mar">Villa del Mar</a>
    <a href="/rezydencje/cool-homes-beach-2">Cool Homes Beach 2</a>
    <a href="/#kontakt">Kontakt</a>
  </nav>

  <a class="header-action" href="/#kontakt">Zarezerwuj</a>

  <button class="nav-toggle" id="nav-toggle" aria-label="Otwórz menu" aria-expanded="false" aria-controls="mobile-nav">
    <span></span>
    <span></span>
    <span></span>
  </button>
</header>

<nav class="mobile-nav" id="mobile-nav" aria-hidden="true">
  <a href="/rezydencje/adhara">ADHARA — Torre del Mar</a>
  <a href="/rezydencje/urban-sky">URBAN SKY — Málaga</a>
  <a href="/rezydencje/villa-del-mar">VILLA DEL MAR — Málaga</a>
  <a href="/rezydencje/cool-homes-beach-2">COOL HOMES BEACH 2 — Costa del Sol Málaga</a>

  <div class="mobile-nav-secondary">
    <a href="/o-sapphire-apartments">O Sapphire Apartments</a>
    <a href="/#kontakt">Kontakt</a>
  </div>

  <a href="/#kontakt" class="mobile-nav-cta">Zarezerwuj</a>

  <div class="lang-switcher">
    <button class="lang-option active" data-lang="pl">PL</button>
    <span class="lang-sep">|</span>
    <button class="lang-option" data-lang="en">EN</button>
    <span class="lang-sep">|</span>
    <button class="lang-option" data-lang="es">ES</button>
    <span class="lang-sep">|</span>
    <button class="lang-option" data-lang="ae">AE</button>
  </div>
</nav>

<script>
  const toggle = document.getElementById("nav-toggle");
  const mobileNav = document.getElementById("mobile-nav");
  const headerLogo = document.getElementById("header-logo") as HTMLImageElement;

  function closeMenu() {
    mobileNav?.classList.remove("open");
    toggle?.classList.remove("open");
    toggle?.setAttribute("aria-expanded", "false");
    mobileNav?.setAttribute("aria-hidden", "true");
    document.body.style.overflow = "";
    document.documentElement.style.overflow = "";
    if (headerLogo) headerLogo.src = "/assets/sapphire-logo-white.svg";
  }

  function openMenu() {
    mobileNav?.classList.add("open");
    toggle?.classList.add("open");
    toggle?.setAttribute("aria-expanded", "true");
    mobileNav?.setAttribute("aria-hidden", "false");
    document.body.style.overflow = "hidden";
    document.documentElement.style.overflow = "hidden";
    if (headerLogo) headerLogo.src = "/assets/sapphire-logo-all-gold.svg";
  }

  toggle?.addEventListener("click", () => {
    if (mobileNav?.classList.contains("open")) {
      closeMenu();
    } else {
      openMenu();
    }
  });

  mobileNav?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", closeMenu);
  });

  // Przełącznik języków (placeholder UI - funkcjonalność i18n do wdrożenia później)
  mobileNav?.querySelectorAll(".lang-option").forEach((btn) => {
    btn.addEventListener("click", (e) => {
      e.preventDefault();
      mobileNav?.querySelectorAll(".lang-option").forEach((b) => b.classList.remove("active"));
      btn.classList.add("active");
    });
  });

  // Efekt "szronu" (frosted glass) na headerze po przewinięciu strony —
  // płynnie pojawiający się blur + gradient, tak jak na przyciskach.
  const header = document.querySelector(".site-header");
  function updateHeaderScrollState() {
    if (!header) return;
    if (window.scrollY > 40) {
      header.classList.add("scrolled");
    } else {
      header.classList.remove("scrolled");
    }
  }
  updateHeaderScrollState();
  window.addEventListener("scroll", updateHeaderScrollState, { passive: true });
</script>
