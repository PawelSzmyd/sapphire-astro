---
// Mapuje tekst udogodnienia na prostą ikonę SVG (styl piktogramów jak na Booking.com).
// Dopasowanie po słowach kluczowych — działa dla PL, wystarczy dodać nowe gałęzie if/else
// jeśli pojawi się udogodnienie, którego nie rozpoznajemy.

interface Props {
  label: string;
}

const { label } = Astro.props;
const text = label.toLowerCase();

function pickIcon(t: string): string {
  if (t.includes("plaż") || t.includes("morz")) return "beach";
  if (t.includes("parking") || t.includes("garaż")) return "car";
  if (t.includes("taras") || t.includes("balkon")) return "sun";
  if (t.includes("internet") || t.includes("światłowod") || t.includes("wifi")) return "wifi";
  if (t.includes("basen")) return "pool";
  if (t.includes("recepcj")) return "bell";
  if (t.includes("co-working") || t.includes("coworking") || t.includes("praca")) return "laptop";
  if (t.includes("architektur") || t.includes("budynek") || t.includes("wież")) return "building";
  if (t.includes("widok") || t.includes("panoram")) return "view";
  if (t.includes("spokoj") || t.includes("lokalizacj")) return "pin";
  if (t.includes("klimatyzacj")) return "snow";
  return "check";
}

const icon = pickIcon(text);

const icons: Record<string, string> = {
  beach: '<path d="M3 21h18M5 21c0-7 4-13 7-13s7 6 7 13M9 12c1-2 3-3 3-3s2 1 3 3" />',
  car: '<path d="M4 17h16M5 17l1.5-5h11L19 17M7 17a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0Zm13 0a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0Z" />',
  sun: '<circle cx="12" cy="12" r="4" /><path d="M12 3v2M12 19v2M4.2 4.2l1.4 1.4M18.4 18.4l1.4 1.4M3 12h2M19 12h2M4.2 19.8l1.4-1.4M18.4 5.6l1.4-1.4" />',
  wifi: '<path d="M2 8.5a15 15 0 0 1 20 0M5.5 12a10 10 0 0 1 13 0M9 15.5a5 5 0 0 1 6 0" /><circle cx="12" cy="19" r="1" fill="currentColor" stroke="none" />',
  pool: '<path d="M3 17c1.5 1 3 1 4.5 0s3-1 4.5 0 3 1 4.5 0 3-1 4.5 0M4 11h16l-1-6H5l-1 6Z" />',
  bell: '<path d="M12 3a5 5 0 0 0-5 5v3c0 1.5-.5 3-2 4.5h14c-1.5-1.5-2-3-2-4.5V8a5 5 0 0 0-5-5ZM9.5 19a2.5 2.5 0 0 0 5 0" />',
  laptop: '<rect x="4" y="5" width="16" height="10" rx="1" /><path d="M2 19h20" />',
  building: '<rect x="6" y="3" width="12" height="18" rx="1" /><path d="M9 7h1M14 7h1M9 11h1M14 11h1M9 15h1M14 15h1" />',
  view: '<path d="M2 13l5-6 4 4 5-7 6 9" /><path d="M2 19h20" />',
  pin: '<path d="M12 21s7-7.2 7-12a7 7 0 1 0-14 0c0 4.8 7 12 7 12Z" /><circle cx="12" cy="9" r="2.5" />',
  snow: '<path d="M12 2v20M4.5 6l15 12M19.5 6l-15 12" />',
  check: '<path d="M5 13l4 4L19 7" />',
};
---

<span class="amenity-icon" aria-hidden="true" set:html={`<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">${icons[icon]}</svg>`} />
