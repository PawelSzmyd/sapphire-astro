---
// SAPPHIRE Apartments narrative carousel - journey through residences
import { residences } from "../data/residences";

const liveResidences = residences.filter(r => r.status === "live");

// Heroic journey narrative with curated images
const heroData = [
  {
    slug: "urban-sky",
    image: "/assets/carousel-hero/urban-sky-pool-aerial.webp",
    tagline: "Above Málaga. Beyond ordinary.",
  },
  {
    slug: "adhara",
    image: "/assets/carousel-hero/adhara-sunset-sea.webp",
    tagline: "Quiet Mediterranean Living.",
  },
  {
    slug: "vega",
    image: "/assets/carousel-hero/vega-terrace-evening.webp",
    tagline: "Effortless Mediterranean elegance.",
  },
  {
    slug: "lumare",
    image: "/assets/carousel-hero/lumare-buildings-below.webp",
    tagline: "Where the cliffs meet the light.",
  },
];

const slides = heroData.map(data => ({
  ...liveResidences.find(r => r.slug === data.slug),
  heroImage: data.image,
  heroTagline: data.tagline,
})).filter(Boolean);
---

<section class="hero-carousel" aria-label="SAPPHIRE Apartments Journey">
  {slides.map((residence, index) => (
    <div 
      class={`carousel-slide ${index === 0 ? 'active' : ''}`}
      data-index={index}
    >
      <div 
        class="carousel-image"
        style={`background-image: url('${residence.heroImage}');`}
      ></div>
      <div class="carousel-overlay"></div>
      <div class="carousel-content">
        <h2 class="carousel-title">{residence.name}</h2>
        <p class="carousel-tagline">{residence.heroTagline}</p>
      </div>
    </div>
  ))}

  <!-- 5-ty slide: Welcome finale -->
  <div class="carousel-slide carousel-welcome-slide" data-index="4">
    <div 
      class="carousel-image carousel-welcome-bg"
      style="background-image: linear-gradient(135deg, #ffa500 0%, #ff6b35 30%, #004e89 100%);"
    ></div>
    <div class="carousel-overlay"></div>
    <div class="carousel-content carousel-welcome-content">
      <div class="welcome-container">
        <p class="welcome-intro">Witaj w</p>
        <h1 class="welcome-headline">SAPPHIRE APARTMENTS</h1>
        <p class="welcome-final-slogan">Where the sky meets the sea.</p>
      </div>
    </div>
  </div>
</section>

<style>
.hero-carousel {
  position: relative;
  width: 100%;
  min-height: 100vh;
  overflow: hidden;
  background: var(--paper);
}

.carousel-slide {
  position: absolute;
  inset: 0;
  opacity: 0;
  z-index: 1;
  display: flex;
  align-items: flex-end;
  pointer-events: none;
}

.carousel-slide.active {
  opacity: 1;
  z-index: 2;
  pointer-events: auto;
}

/* Zdjęcie z efektem zoom-out + blur-to-sharp */
.carousel-image {
  position: absolute;
  inset: 0;
  background-size: cover;
  background-position: center;
  background-repeat: no-repeat;
}

.carousel-slide.active .carousel-image {
  animation: zoomOutBlur 3.5s ease-out forwards;
}

@keyframes zoomOutBlur {
  0% {
    transform: scale(1.15);
    filter: blur(12px);
    opacity: 1;
  }
  40% {
    filter: blur(8px);
  }
  70% {
    filter: blur(3px);
  }
  100% {
    transform: scale(1);
    filter: blur(0);
    opacity: 1;
  }
}

.carousel-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(22, 20, 15, 0.3) 0%, rgba(22, 20, 15, 0.7) 100%);
  z-index: 1;
}

.carousel-content {
  position: relative;
  z-index: 2;
  color: var(--white);
  padding: clamp(56px, 12vw, 120px) clamp(18px, 6vw, 86px);
  width: 100%;
  animation: slideContentIn 1200ms cubic-bezier(0.34, 1.56, 0.64, 1) 1400ms both;
}

@keyframes slideContentIn {
  from {
    opacity: 0;
    transform: translateY(40px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.carousel-title {
  margin: 0 0 16px;
  font-family: "Cormorant Garamond", Georgia, serif;
  font-size: clamp(2.2rem, 6vw, 4rem);
  font-weight: 500;
  line-height: 1;
  letter-spacing: -0.02em;
}

.carousel-tagline {
  margin: 0;
  font-size: clamp(1.1rem, 3.5vw, 1.8rem);
  color: rgba(255, 253, 248, 0.95);
  max-width: 540px;
  line-height: 1.7;
  font-weight: 300;
  animation: slideTaglineIn 1000ms ease-out 1800ms both;
}

@keyframes slideTaglineIn {
  from {
    opacity: 0;
    transform: translateY(20px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* Welcome slide styling */
.carousel-welcome-slide {
  pointer-events: auto !important;
}

.carousel-welcome-bg {
  filter: brightness(0.95);
}

.carousel-welcome-slide.active .carousel-welcome-bg {
  animation: zoomOutBlur 3.5s ease-out forwards;
}

.carousel-welcome-content {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.welcome-container {
  text-align: center;
  max-width: 600px;
  animation: welcomeContentFadeIn 1200ms cubic-bezier(0.34, 1.56, 0.64, 1) 1400ms both;
}

@keyframes welcomeContentFadeIn {
  from {
    opacity: 0;
    transform: scale(0.9) translateY(24px);
  }
  to {
    opacity: 1;
    transform: scale(1) translateY(0);
  }
}

.welcome-intro {
  margin: 0 0 16px;
  font-size: clamp(1rem, 3vw, 1.4rem);
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: rgba(255, 253, 248, 0.8);
  animation: charFadeIn 600ms ease-out 3400ms both;
}

.welcome-headline {
  margin: 0 0 24px;
  font-family: "Cormorant Garamond", Georgia, serif;
  font-size: clamp(2.8rem, 8vw, 5.8rem);
  font-weight: 500;
  line-height: 1;
  letter-spacing: 0.06em;
  color: var(--white);
  animation: textReveal 1100ms ease-out 3500ms both;
}

.welcome-final-slogan {
  margin: 0;
  font-size: clamp(0.95rem, 2.5vw, 1.7rem);
  color: var(--gold);
  letter-spacing: 0.04em;
  font-style: italic;
  font-weight: 300;
  animation: sloganFadeIn 700ms ease-out 3800ms both;
}

@keyframes charFadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

@keyframes textReveal {
  from {
    opacity: 0;
    transform: translateY(40px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes sloganFadeIn {
  from {
    opacity: 0;
    transform: translateY(16px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@media (max-width: 720px) {
  .carousel-content {
    padding: clamp(40px, 8vw, 80px) clamp(16px, 5vw, 56px);
  }

  .carousel-title {
    font-size: clamp(1.8rem, 5.5vw, 2.8rem);
    margin-bottom: 12px;
  }

  .carousel-tagline {
    font-size: clamp(0.95rem, 3vw, 1.4rem);
  }

  .welcome-headline {
    font-size: clamp(2.2rem, 6.5vw, 3.8rem);
  }

  .welcome-intro {
    font-size: clamp(0.8rem, 2.5vw, 1rem);
  }

  .welcome-final-slogan {
    font-size: clamp(0.85rem, 2vw, 1.2rem);
  }
}
</style>

<script>
  let currentIndex = 0;
  const slides = document.querySelectorAll(".carousel-slide");
  const totalSlides = slides.length;
  let autoplayTimeout: ReturnType<typeof setTimeout> | null = null;

  function showSlide(index: number) {
    // Wyłącz poprzednie
    slides.forEach((slide) => slide.classList.remove("active"));

    // Pokaż nowe
    currentIndex = index % totalSlides;
    slides[currentIndex].classList.add("active");

    // Zaplanuj następne
    if (autoplayTimeout) clearTimeout(autoplayTimeout);
    autoplayTimeout = setTimeout(() => {
      showSlide(currentIndex + 1);
    }, 6500);
  }

  // Start
  showSlide(0);
</script>
