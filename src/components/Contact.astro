---
// Lista rezydencji w dropdownie formularza pochodzi z tych samych danych
// co karty rezydencji — nigdy nie wyjdzie z synchronizacji.
import { residences } from "../data/residences";
---

<section class="section contact reveal" id="kontakt">
  <div class="contact-intro">
    <div class="section-label">Kontakt</div>
    <h2>Rozpocznij swój pobyt.</h2>
    <p>Niezależnie od tego, czy planujesz krótki pobyt, pracę zdalną w Hiszpanii czy dłuższy pobyt na Costa del Sol — jesteśmy do Twojej dyspozycji.</p>
  </div>
  <div class="contact-grid">
    <div>
      <h3>Lokalizacja</h3>
      <p>Costa del Sol<br />Andaluzja, Hiszpania</p>
    </div>
    <div>
      <h3>Kontakt</h3>
      <div class="contact-actions">
        <a href="mailto:hello@sapphire-apartments.com">E-mail</a>
        <a href="https://wa.me/" target="_blank" rel="noreferrer">WhatsApp</a>
      </div>
    </div>
    <div>
      <h3>Obsługa</h3>
      <p>Odpowiadamy na wszystkie zapytania w ciągu 24 godzin.</p>
    </div>
  </div>
  <form class="contact-form" id="contact-form" action="https://formsubmit.co/bok.reklama@gmail.com" method="POST">
    <input type="hidden" name="_subject" value="Nowe zapytanie — SAPPHIRE Apartments" />
    <input type="hidden" name="_template" value="table" />
    <input type="hidden" name="_captcha" value="false" />
    <label>
      Imię i nazwisko
      <input name="name" autocomplete="name" required />
    </label>
    <label>
      E-mail
      <input name="email" type="email" autocomplete="email" required />
    </label>
    <label>
      Rezydencja
      <select name="residence">
        {residences.map((residence) => (
          <option>{residence.name} — {residence.location}</option>
        ))}
        <option>Nie jestem jeszcze zdecydowany/a</option>
      </select>
    </label>
    <label class="full-width">
      Wiadomość
      <textarea name="message" rows="5" required></textarea>
    </label>
    <button class="button primary dark" type="submit">Wyślij zapytanie</button>
    <p class="form-status" id="form-status" role="status" aria-live="polite"></p>
  </form>
</section>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement | null;
  const status = document.getElementById("form-status");

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!form || !status) return;

    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
    const originalLabel = submitBtn?.textContent ?? "Wyślij zapytanie";

    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = "Wysyłanie...";
    }
    status.classList.remove("is-visible", "is-error");
    status.textContent = "";

    try {
      const formData = new FormData(form);
      const response = await fetch(form.action, {
        method: "POST",
        body: formData,
        headers: { Accept: "application/json" },
      });

      if (response.ok) {
        form.reset();
        status.textContent = "Dziękujemy! Twoje zapytanie zostało wysłane — odpowiemy w ciągu 24 godzin.";
        requestAnimationFrame(() => status.classList.add("is-visible"));
      } else {
        throw new Error("Send failed");
      }
    } catch (err) {
      status.textContent = "Coś poszło nie tak. Spróbuj ponownie lub napisz na hello@sapphire-apartments.com.";
      status.classList.add("is-error");
      requestAnimationFrame(() => status.classList.add("is-visible"));
    } finally {
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = originalLabel;
      }
    }
  });
</script>
