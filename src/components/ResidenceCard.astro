---
// Jedna karta rezydencji. Renderowana w pętli przez Residences.astro,
// raz dla każdego obiektu z src/data/residences.ts.
//
// `reverse` odwraca układ (zdjęcie/tekst) na zmianę, tak jak w starej wersji
// (ADHARA: zdjęcie po lewej, URBAN SKY: zdjęcie po prawej, itd.)

import type { Residence } from "../data/residences";

interface Props {
  residence: Residence;
  reverse: boolean;
  index?: number;
}

const { residence, reverse, index = 0 } = Astro.props;
const isComingSoon = residence.status === "coming-soon";
const hasImage = Boolean(residence.image);
const linkHref = isComingSoon ? "#kontakt" : `/rezydencje/${residence.slug}`;
const indexLabel = String(index + 1).padStart(3, "0");
---

<article class={`residence feature reveal ${reverse ? "reverse" : ""} ${isComingSoon ? "coming-soon" : ""}`}>
  <a class="residence-image-link" href={linkHref} aria-label={`Zobacz ${residence.name} — ${residence.location}`}>
    {hasImage ? (
      <div
        class="residence-image"
        style={`background-image: url('${residence.image}'); background-position: 50% center;`}
        role="img"
        aria-label={residence.imageAlt}
      >
        {isComingSoon && <span class="status-badge on-image">Wkrótce</span>}
      </div>
    ) : (
      <div class="residence-image placeholder" role="img" aria-label={`${residence.name} — rezydencja w przygotowaniu`}>
        <span class="placeholder-name">{residence.name}</span>
      </div>
    )}
  </a>

  <div class="residence-body">
    {isComingSoon && <span class="status-badge">Wkrótce</span>}
    <div class="residence-index">
      <span class="index-square"></span>
      <span class="index-line"></span>
      <span class="index-number">{indexLabel}</span>
    </div>
    <p class="overline">{residence.name} — {residence.location}</p>
    <h3>{residence.tagline}</h3>
    {residence.paragraphs.map((paragraph) => <p>{paragraph}</p>)}

    {residence.amenities.length > 0 && (
      <ul class="amenities">
        {residence.amenities.map((item) => <li>{item}</li>)}
      </ul>
    )}

    <a class="text-link" href={linkHref}>{residence.ctaLabel}</a>
  </div>
</article>
