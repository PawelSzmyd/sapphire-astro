---
// To jest "szkielet" strony: head, czcionki, globalny CSS.
// Każda strona (np. src/pages/index.astro) owija swoją treść w <Layout>...</Layout>
// i automatycznie dostaje ten sam <head>, header i footer.

import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";
import "../styles/coming-soon.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "SAPPHIRE Apartments | Residences of Rare Distinction",
  description = "SAPPHIRE Apartments - starannie wyselekcjonowane rezydencje premium na Costa del Sol.",
} = Astro.props;
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=Montserrat:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Header />
    <main id="top">
      <slot />
    </main>
    <Footer />
  </body>
</html>
