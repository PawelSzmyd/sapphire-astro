---
// To jest "szkielet" strony: head, czcionki, globalny CSS.
// Każda strona (np. src/pages/index.astro) owija swoją treść w <Layout>...</Layout>
// i automatycznie dostaje ten sam <head>, header i footer.

import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";
import "../styles/coming-soon.css";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = "SAPPHIRE Apartments | Residences of Rare Distinction",
  description = "SAPPHIRE Apartments - starannie wyselekcjonowane rezydencje premium na Costa del Sol.",
  ogImage = "/assets/urban-sky.jpg",
} = Astro.props;
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=Montserrat:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Header />
    <main id="top">
      <slot />
    </main>
    <Footer />

    <script>
      // Globalna animacja "wynurzania się" elementów podczas scrollowania.
      // Elementy z klasą .reveal startują niewidoczne/rozmyte, a po wejściu
      // w viewport płynnie się pojawiają (klasa .is-visible, patrz global.css).
      function initScrollReveal() {
        const revealEls = document.querySelectorAll<HTMLElement>(".reveal");
        if (!revealEls.length) return;

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                observer.unobserve(entry.target);
              }
            });
          },
          {
            threshold: 0.12,
            rootMargin: "0px 0px -60px 0px",
          }
        );

        revealEls.forEach((el) => observer.observe(el));
      }

      initScrollReveal();
      document.addEventListener("astro:page-load", initScrollReveal);
    </script>
  </body>
</html>
