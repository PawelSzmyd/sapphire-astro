---
// Astro generuje jedną statyczną podstronę dla KAŻDEJ rezydencji z src/data/residences.ts —
// niezależnie od statusu (live / coming-soon). Dla "coming-soon" treść jest uboższa
// (brak galerii/mapy/FAQ, tylko nagłówek + opis + CTA "Dołącz do listy prywatnej"),
// dokładnie tak jak dla ADHARY na początku — wystarczy uzupełnić dane w residences.ts,
// żeby strona "ożyła" bez zmian w tym szablonie.

import Layout from "../../layouts/Layout.astro";
import { residences } from "../../data/residences";
import AmenityIcon from "../../components/AmenityIcon.astro";
import "../../styles/residence-detail.css";

export function getStaticPaths() {
  return residences.map((residence) => ({
    params: { slug: residence.slug },
    props: { residence },
  }));
}

const { residence } = Astro.props;
const isLive = residence.status === "live";
const heroImage = residence.gallery?.[0]?.src ?? residence.image;
---

<Layout title={`${residence.name} — SAPPHIRE Apartments`} description={residence.tagline}>
  <section class="residence-hero" style={heroImage ? `background-image: url('${heroImage}');` : ""}>
    <div class="residence-hero-content">
      <a class="breadcrumb" href="/">← Strona główna</a>
      <p class="overline">
        {residence.name} — {residence.location}
        {!isLive && <span class="status-badge inline">Wkrótce</span>}
      </p>
      <h1>{residence.tagline}</h1>
    </div>
  </section>

  {residence.gallery && residence.gallery.length > 0 && (
    <div class="gallery-grid" id="gallery">
      {residence.gallery.map((image, index) => (
        <figure>
          <img
            src={image.src}
            alt={image.alt}
            loading="lazy"
            class="lightbox-trigger"
            data-index={index}
            tabindex="0"
            role="button"
            aria-label={`Powiększ zdjęcie: ${image.alt}`}
          />
          {image.caption && <figcaption>{image.caption}</figcaption>}
        </figure>
      ))}
    </div>
  )}

  <div class="residence-detail-body">
    <div class="prose">
      {residence.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
    </div>

    {residence.amenities.length > 0 && (
      <>
        <h2 class="amenities-heading">Udogodnienia</h2>
        <div class="amenities-grid">
          {residence.amenities.map((item) => (
            <div class="amenity-pill">
              <AmenityIcon label={item} />
              <span>{item}</span>
            </div>
          ))}
        </div>
      </>
    )}
  </div>

  {isLive && residence.mapQuery && (
    <section class="residence-location">
      <div class="residence-location-text">
        <div class="section-label">Lokalizacja</div>
        <h2>{residence.areaTitle}</h2>
        {residence.areaDescription && <p>{residence.areaDescription}</p>}
      </div>
      <div class="map-embed">
        <iframe
          src={`https://www.google.com/maps?q=${encodeURIComponent(residence.mapQuery)}&output=embed`}
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          allowfullscreen
          title={`Mapa — ${residence.areaTitle}`}
        ></iframe>
      </div>
    </section>
  )}

  {isLive && residence.faq && residence.faq.length > 0 && (
    <section class="residence-faq">
      <div class="section-label">Najczęściej zadawane pytania</div>
      <h2>FAQ</h2>
      <div class="faq-list">
        {residence.faq.map((item) => (
          <details>
            <summary>{item.question}</summary>
            <p>{item.answer}</p>
          </details>
        ))}
      </div>
    </section>
  )}

  <div class="residence-cta-block">
    {isLive ? (
      <div class="cta-row">
        <a class="button primary dark" href="/#kontakt">Zarezerwuj {residence.name}</a>
        {residence.bookingUrl && (
          <a class="button secondary" href={residence.bookingUrl} target="_blank" rel="noopener noreferrer">
            Rezerwuj i zapłać na Booking.com
          </a>
        )}
      </div>
    ) : (
      <a class="button primary dark" href="/#kontakt">Dołącz do listy prywatnej</a>
    )}
  </div>

  {residence.gallery && residence.gallery.length > 0 && (
    <div class="lightbox" id="lightbox" aria-hidden="true">
      <button class="lightbox-close" id="lightbox-close" aria-label="Zamknij powiększenie">✕</button>
      <button class="lightbox-nav lightbox-prev" id="lightbox-prev" aria-label="Poprzednie zdjęcie">‹</button>
      <img class="lightbox-image" id="lightbox-image" src="" alt="" />
      <button class="lightbox-nav lightbox-next" id="lightbox-next" aria-label="Następne zdjęcie">›</button>
      <p class="lightbox-caption" id="lightbox-caption"></p>
    </div>
  )}
</Layout>

<script>
  // Lightbox: powiększanie zdjęć galerii po kliknięciu.
  // Czysty JS bez frameworka — działa na statycznej stronie Astro.
  const triggers = Array.from(document.querySelectorAll<HTMLImageElement>(".lightbox-trigger"));
  const lightbox = document.getElementById("lightbox");
  const lightboxImage = document.getElementById("lightbox-image") as HTMLImageElement | null;
  const lightboxCaption = document.getElementById("lightbox-caption");
  const closeBtn = document.getElementById("lightbox-close");
  const prevBtn = document.getElementById("lightbox-prev");
  const nextBtn = document.getElementById("lightbox-next");

  let currentIndex = 0;

  function openLightbox(index: number) {
    if (!lightbox || !lightboxImage || triggers.length === 0) return;
    currentIndex = (index + triggers.length) % triggers.length;
    const img = triggers[currentIndex];
    lightboxImage.src = img.src;
    lightboxImage.alt = img.alt;
    if (lightboxCaption) lightboxCaption.textContent = img.alt;
    lightbox.classList.add("open");
    lightbox.setAttribute("aria-hidden", "false");
    document.body.style.overflow = "hidden";
  }

  function closeLightbox() {
    if (!lightbox) return;
    lightbox.classList.remove("open");
    lightbox.setAttribute("aria-hidden", "true");
    document.body.style.overflow = "";
  }

  triggers.forEach((img, index) => {
    img.addEventListener("click", () => openLightbox(index));
    img.addEventListener("keydown", (e: KeyboardEvent) => {
      if (e.key === "Enter" || e.key === " ") {
        e.preventDefault();
        openLightbox(index);
      }
    });
  });

  closeBtn?.addEventListener("click", closeLightbox);
  prevBtn?.addEventListener("click", () => openLightbox(currentIndex - 1));
  nextBtn?.addEventListener("click", () => openLightbox(currentIndex + 1));

  lightbox?.addEventListener("click", (e) => {
    if (e.target === lightbox) closeLightbox();
  });

  document.addEventListener("keydown", (e: KeyboardEvent) => {
    if (!lightbox?.classList.contains("open")) return;
    if (e.key === "Escape") closeLightbox();
    if (e.key === "ArrowLeft") openLightbox(currentIndex - 1);
    if (e.key === "ArrowRight") openLightbox(currentIndex + 1);
  });
</script>
